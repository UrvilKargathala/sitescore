generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Scan {
  id                 String     @id @default(uuid())
  jobId              String?    @unique  // BullMQ job ID, set after enqueue
  url                String
  origin             String     // normalized origin for dedup
  status             ScanStatus @default(PENDING)
  rulebookVersion    String     @default("v1")

  overallScore       Int?
  performanceScore   Int?
  seoScore           Int?
  securityScore      Int?
  accessibilityScore Int?
  mobileScore        Int?

  // Raw probe output — scored in FR-6
  lighthouseDesktop  Json?
  lighthouseMobile   Json?
  securityJson       Json?
  axeJson            Json?

  resultJson    Json?
  errorReason   String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  lead Lead?

  @@index([jobId])
}

model Lead {
  id        String   @id @default(uuid())
  scanId    String   @unique
  scan      Scan     @relation(fields: [scanId], references: [id])
  email     String
  consent   Boolean  @default(false)
  consentAt DateTime?

  // PDF delivery lifecycle
  deliveryStatus String    @default("pending") // pending | sent | failed
  deliveryJobId  String?   // BullMQ job ID for the report job
  pdfSentAt      DateTime?
  deliveryError  String?

  deleteRequestedAt DateTime?
  expiresAt DateTime  // retention window (GDPR/DPDP)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  PARTIAL
}
